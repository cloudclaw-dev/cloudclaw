# CloudClaw Environment Configuration
# Copy this file to .env and fill in the values

# Required: JWT secret for authentication (min 32 characters)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# LLM API key encryption key (32 hex chars = 128-bit AES key)
LLM_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Database password (cluster mode only)
DB_PASSWORD=cloudclaw123

# External port
PORT=8080
